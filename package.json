{
  "name": "@moku-labs/core",
  "version": "0.1.0-alpha.5",
  "author": "Alex Kucherenko",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moku-labs/core.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@arethetypeswrong/core": "0.18.2",
    "@biomejs/biome": "2.4.2",
    "@types/bun": "1.3.9",
    "@vitest/coverage-istanbul": "4.0.18",
    "eslint": "9",
    "eslint-config-biome": "2.1.3",
    "eslint-plugin-jsdoc": "62.6.0",
    "eslint-plugin-sonarjs": "4.0.0",
    "eslint-plugin-unicorn": "63.0.0",
    "globals": "17.3.0",
    "jiti": "2.6.1",
    "lefthook": "2.1.1",
    "publint": "0.3.17",
    "tsdown": "0.20.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.0",
    "vitest": "4.0.18"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bugs": {
    "url": "https://github.com/moku-labs/core/issues"
  },
  "description": "Micro-kernel plugin framework for LLMs (TypeScript)",
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.8"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "homepage": "https://github.com/moku-labs/core#readme",
  "keywords": [
    "plugin",
    "framework",
    "micro-kernel",
    "typescript",
    "lifecycle",
    "event-bus",
    "type-safe"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "validate": "publint && attw --pack . --profile node16",
    "lint": "biome check . && eslint .",
    "lint:fix": "biome check --write . && eslint --fix .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:sandbox": "vitest run --project sandbox",
    "test:coverage": "vitest run --project unit --project integration --coverage"
  },
  "type": "module",
  "types": "./dist/index.d.mts"
}
