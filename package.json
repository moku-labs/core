{
  "name": "moku_core",
  "version": "0.0.0",
  "description": "Micro-kernel plugin framework for TypeScript",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Oleksand Kucherenko",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicecatch/moku_core"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.8"
  },
  "keywords": [
    "plugin",
    "framework",
    "micro-kernel",
    "typescript",
    "lifecycle",
    "event-bus",
    "type-safe"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/testing.d.mts",
        "default": "./dist/testing.mjs"
      },
      "require": {
        "types": "./dist/testing.d.cts",
        "default": "./dist/testing.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "tsdown",
    "validate": "publint && attw --pack . --profile node16"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@arethetypeswrong/core": "0.18.2",
    "@types/bun": "1.3.9",
    "lefthook": "2.1.1",
    "publint": "0.3.17",
    "tsdown": "0.20.3",
    "typescript": "5.9.3"
  }
}
